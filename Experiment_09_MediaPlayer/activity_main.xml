<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#1A1A2E">

    <!-- App Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎵 Media Player"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#E94560"
        android:layout_marginBottom="10dp"/>

    <!-- Song Name Display -->
    <TextView
        android:id="@+id/tvSongName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="song.mp3"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="30dp"/>

    <!-- Current Time / Total Duration -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="5dp">

        <TextView
            android:id="@+id/tvCurrentTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0:00"
            android:textColor="#AAAAAA"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/tvTotalTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0:00"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:gravity="end"/>

    </LinearLayout>

    <!--
        SeekBar = shows song progress
        User can drag it to seek to a position
    -->
    <SeekBar
        android:id="@+id/seekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:progressTint="#E94560"
        android:thumbTint="#E94560"/>

    <!-- Playback Control Buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- PLAY Button -->
        <Button
            android:id="@+id/btnPlay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶ Play"
            android:backgroundTint="#E94560"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="10dp"/>

        <!-- PAUSE Button -->
        <Button
            android:id="@+id/btnPause"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏸ Pause"
            android:backgroundTint="#16213E"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="10dp"/>

        <!-- STOP Button -->
        <Button
            android:id="@+id/btnStop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏹ Stop"
            android:backgroundTint="#0F3460"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

    <!-- Status Text -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status: Ready"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:layout_marginTop="30dp"/>

</LinearLayout>
