<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/grid_layout_demo"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFD600"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/experiment_5"
        android:textSize="13sp"
        android:textColor="#757575"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="4"
        android:useDefaultMargins="true">

        <Button android:id="@+id/btn1" android:text="@string/btn_1" android:layout_columnWeight="1" android:backgroundTint="#1E1E1E" android:textColor="#FFFFFF" android:textSize="18sp"/>
        <Button android:id="@+id/btn2" android:text="@string/btn_2" android:layout_columnWeight="1" android:backgroundTint="#1E1E1E" android:textColor="#FFFFFF" android:textSize="18sp"/>
        <Button android:id="@+id/btn3" android:text="@string/btn_3" android:layout_columnWeight="1" android:backgroundTint="#1E1E1E" android:textColor="#FFFFFF" android:textSize="18sp"/>
        <Button android:id="@+id/btnAdd" android:text="@string/btn_add" android:layout_columnWeight="1" android:backgroundTint="#FF6F00" android:textColor="#FFFFFF" android:textSize="22sp"/>

        <Button android:id="@+id/btn4" android:text="@string/btn_4" android:layout_columnWeight="1" android:backgroundTint="#1E1E1E" android:textColor="#FFFFFF" android:textSize="18sp"/>
        <Button android:id="@+id/btn5" android:text="@string/btn_5" android:layout_columnWeight="1" android:backgroundTint="#1E1E1E" android:textColor="#FFFFFF" android:textSize="18sp"/>
        <Button android:id="@+id/btn6" android:text="@string/btn_6" android:layout_columnWeight="1" android:backgroundTint="#1E1E1E" android:textColor="#FFFFFF" android:textSize="18sp"/>
        <Button android:id="@+id/btnSub" android:text="@string/btn_sub" android:layout_columnWeight="1" android:backgroundTint="#FF6F00" android:textColor="#FFFFFF" android:textSize="22sp"/>

        <Button android:id="@+id/btn7" android:text="@string/btn_7" android:layout_columnWeight="1" android:backgroundTint="#1E1E1E" android:textColor="#FFFFFF" android:textSize="18sp"/>
        <Button android:id="@+id/btn8" android:text="@string/btn_8" android:layout_columnWeight="1" android:backgroundTint="#1E1E1E" android:textColor="#FFFFFF" android:textSize="18sp"/>
        <Button android:id="@+id/btn9" android:text="@string/btn_9" android:layout_columnWeight="1" android:backgroundTint="#1E1E1E" android:textColor="#FFFFFF" android:textSize="18sp"/>
        <Button android:id="@+id/btnMul" android:text="@string/btn_mul" android:layout_columnWeight="1" android:backgroundTint="#FF6F00" android:textColor="#FFFFFF" android:textSize="22sp"/>

        <Button android:id="@+id/btnClear" android:text="@string/btn_clear" android:layout_columnWeight="1" android:backgroundTint="#B71C1C" android:textColor="#FFFFFF" android:textSize="18sp"/>
        <Button android:id="@+id/btn0" android:text="@string/btn_0" android:layout_columnWeight="1" android:backgroundTint="#1E1E1E" android:textColor="#FFFFFF" android:textSize="18sp"/>
        <Button android:id="@+id/btnEquals" android:text="@string/btn_equals" android:layout_columnWeight="1" android:backgroundTint="#2E7D32" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnDiv" android:text="@string/btn_div" android:layout_columnWeight="1" android:backgroundTint="#FF6F00" android:textColor="#FFFFFF" android:textSize="22sp"/>

    </GridLayout>
</LinearLayout>
